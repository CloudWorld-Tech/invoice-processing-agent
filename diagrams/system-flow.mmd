    style Backend fill:#16213e,stroke:#4a9eff,color:#fff
    style Agent fill:#0f3460,stroke:#e94560,color:#fff
    style Observability fill:#1a1a2e,stroke:#53d769,color:#fff
    style LLM fill:#16213e,stroke:#f5a623,color:#fff
