# Mock mode (set to true to skip real LLM calls)
MOCK_MODE=true

# OpenAI / Azure OpenAI configuration
OPENAI_API_KEY=your-api-key-here
# Standard OpenAI:  https://api.openai.com/v1
# Azure OpenAI:     https://your-resource.openai.azure.com  (no trailing path)
OPENAI_BASE_URL=https://your-resource.openai.azure.com
OPENAI_MODEL=gpt-4o
# Azure only: API version (auto-detected when URL contains "azure")
AZURE_API_VERSION=2024-12-01-preview

# LangSmith tracing (optional, but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=invoice-agent
